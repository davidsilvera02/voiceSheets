# ---------------------------------------------------------------------------
# VoiceSheets environment configuration
# Copy this file to `.env` and fill in the values you need.
# The app is designed to run in a degraded-but-functional "dev" mode even when
# the optional integrations (Clerk, Anthropic, Whisper) are not configured.
#
# NEVER put real secrets in this file — it is committed to git.
# ---------------------------------------------------------------------------

# --- Database (required) ---------------------------------------------------
# Local Docker default (see docker-compose.yml). For Supabase/Neon/etc. paste
# the connection string from your provider.
DATABASE_URL="postgresql://voicesheets:voicesheets@localhost:5432/voicesheets?schema=public"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Authentication: Clerk (optional) -------------------------------------
# When these are blank, VoiceSheets runs in single-user DEV mode using a
# seeded local user, so you can develop without a Clerk account.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- AI: Anthropic Claude (optional) --------------------------------------
# When blank, the AI service falls back to a deterministic heuristic parser so
# the voice/AI review flow is still demoable end-to-end without an API key.
ANTHROPIC_API_KEY=""
# Model id used for structured extraction. See the claude-api reference.
ANTHROPIC_MODEL="claude-sonnet-5"

# --- Speech-to-text: Whisper (optional) -----------------------------------
# OpenAI Whisper API is used server-side to transcribe recorded audio.
# When blank, the client lets the user type/paste the transcript instead.
OPENAI_API_KEY=""
WHISPER_MODEL="whisper-1"

# --- Feature flags --------------------------------------------------------
# Set to "true" to force single-user dev auth even when Clerk keys are present.
VOICESHEETS_FORCE_DEV_AUTH="false"
